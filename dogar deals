            <div class="bg-white p-4 rounded-2xl shadow-sm hover:shadow-md transition product-card">
                <img src="https://m.media-amazon.com/images/I/71XmCq-0q2L._AC_SL1500_.jpg" alt="Magic Book">
                <h3 class="font-bold mt-3 text-gray-800">Sank Magic Practice Book Set</h3>
