        </div>
    </main>

    <script>
        function order(pName, pPrice) {
            const name = prompt("Apna Naam Likhein:");
            const city = prompt("City ka naam:");
            const phone = prompt("Contact Number:");
            const myNumber = "923111504504";

            if (name && city && phone) {
                const msg = `*DOGAR DEALS - NEW ORDER*%0A%0A*Item:* ${pName}%0A*Price:* Rs. ${pPrice}%0A%0A*Customer:* ${name}%0A*City:* ${city}%0A*Phone:* ${phone}%0A*Payment:* Cash on Delivery`;
                window.open(`https://wa.me/${myNumber}?text=${msg}`, '_blank');
            }
        }
    </script>
</body>
</html>
