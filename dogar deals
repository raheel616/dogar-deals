                <button onclick="order('Non-Stick Pan', '2650')" class="w-full mt-3 bg-green-500 text-white py-2 rounded-lg font-bold">Order on WhatsApp</button>
            </div>

            <div class="bg-white p-4 rounded-2xl shadow-sm hover:shadow-md transition product-card">
